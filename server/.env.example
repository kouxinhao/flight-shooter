PORT=3001
JWT_SECRET=your-secret-key-here

# QQ 邮箱 SMTP 配置（用于发送登录验证码）
# MAIL_HOST:      SMTP 服务器地址
# MAIL_PORT:      SMTP 端口（465=SSL, 587=TLS）
# MAIL_USER:      发信邮箱账号
# MAIL_PASS:      授权码（QQ邮箱 → 设置 → 账号 → POP3/SMTP服务 → 生成授权码）
# MAIL_FROM:      发信人地址（通常与 MAIL_USER 相同）
MAIL_HOST=smtp.qq.com
MAIL_PORT=465
MAIL_USER=your@qq.com
MAIL_PASS=your-authorization-code
MAIL_FROM=your@qq.com