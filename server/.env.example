PORT=3001
JWT_SECRET=your-secret-key-here

# SendGrid 配置（用于发送登录验证码，推荐）
# 注册: https://signup.sendgrid.com → 免费账户 100 封/天
# 创建 API Key: Settings → API Keys → Create API Key (Full Access)
# SENDGRID_API_KEY:  SendGrid API Key
# SENDGRID_FROM:     发件人邮箱（需要在 SendGrid 中验证发件人）
SENDGRID_API_KEY=
SENDGRID_FROM=

# 注意：不配置 SendGrid 时，验证码会打印到服务器日志（开发模式）
# 去 Railway 项目 → Logs 中查看验证码即可登录